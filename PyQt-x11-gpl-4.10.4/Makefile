	cp -f /home/cct/LabRAD/PyQt-x11-gpl-4.10.4/__init__.py $(DESTDIR)/home/cct/.virtualenvs/labrad/lib/python2.7/site-packages/PyQt4/__init__.py
	cp -f pyqtconfig.py $(DESTDIR)/home/cct/.virtualenvs/labrad/lib/python2.7/site-packages/PyQt4/pyqtconfig.py

